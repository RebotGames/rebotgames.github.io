---
const year = new Date().getFullYear();
---
<footer class="footer">
  <div class="links">
    <a href="mailto:hello@rebotgames.com">hello@rebotgames.com</a>
    <a href="https://github.com/RebotGames" target="_blank" rel="noopener noreferrer">GitHub</a>
  </div>
  <p class="copyright">&copy; {year} RebotGames</p>
</footer>

<style>
  .footer {
    text-align: center;
    padding: 2rem 1.5rem;
    border-top: 1px solid var(--color-border);
    margin-top: 1rem;
  }
  .links {
    display: flex;
    justify-content: center;
    gap: 1.5rem;
    margin-bottom: 0.75rem;
  }
  .links a {
    color: var(--color-muted);
  }
  .links a:hover {
    color: var(--color-fg);
  }
  .copyright {
    color: var(--color-muted);
    font-size: 0.85rem;
  }
</style>
