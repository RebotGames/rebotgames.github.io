---
const steamUrl = 'https://store.steampowered.com/app/4516640/Megabait/';
---
<section class="game" id="megabait">
  <h2>Megabait</h2>
  <img
    class="capsule"
    src="/images/capsule_horizontal.jpg"
    alt="Megabait"
    width="616"
    height="353"
    loading="lazy"
  />
  <p>
    A brutal top-down obstacle course where every second counts. Master
    precise movement to survive deadly hazard rooms, leave a bloody trail of
    your past mistakes, and uncover every secret on your path to 100%
    completion.
  </p>
  <div class="links">
    <a class="store-link" href={steamUrl} target="_blank" rel="noopener noreferrer">Wishlist on Steam</a>
  </div>
  <video
    class="gameplay-clip"
    src="/videos/megabait-gameplay.webm"
    poster="/images/capsule_horizontal.jpg"
    width="640"
    height="360"
    autoplay
    loop
    muted
    playsinline
  >
  </video>
</section>

<style>
  .game {
    max-width: 48rem;
    margin: 0 auto;
    padding: 2rem 1.5rem 3rem;
    text-align: center;
  }
  h2 {
    margin-bottom: 1rem;
  }
  .capsule {
    width: 100%;
    max-width: 460px;
    height: auto;
    border-radius: 8px;
    margin-bottom: 1.25rem;
  }
  p {
    color: var(--color-muted);
    line-height: 1.6;
    margin-bottom: 1.5rem;
  }
  .gameplay-clip {
    width: 100%;
    max-width: 460px;
    height: auto;
    border-radius: 8px;
  }
  .links {
    display: flex;
    justify-content: center;
    gap: 1rem;
    flex-wrap: wrap;
    margin-bottom: 1.5rem;
  }
  .store-link {
    display: inline-block;
    padding: 0.6rem 1.2rem;
    border-radius: 6px;
    border: 1px solid var(--color-border);
    font-size: 0.95rem;
    color: var(--color-accent);
  }
  .store-link:hover {
    border-color: var(--color-accent);
  }
</style>
