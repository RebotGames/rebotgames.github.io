<header class="hero">
  <img class="logo" src="/images/logo.png" alt="RebotGames logo" width="96" height="96" />
  <h1>RebotGames</h1>
  <p class="tagline">Small studio. Sharp hooks. Currently building <strong>Megabait</strong>.</p>
</header>

<style>
  .hero {
    text-align: center;
    padding: 4rem 1.5rem 3rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
  }
  .logo {
    border-radius: 16px;
    background: #fff;
  }
  h1 {
    font-size: 2.5rem;
    margin: 0;
    letter-spacing: 0.02em;
  }
  .tagline {
    color: var(--color-muted);
    font-size: 1.1rem;
    max-width: 32rem;
  }
</style>
