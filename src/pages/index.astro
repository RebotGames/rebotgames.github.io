---
import Hero from '../components/Hero.astro';
import About from '../components/About.astro';
import GameSection from '../components/GameSection.astro';
import Footer from '../components/Footer.astro';
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
		<link rel="icon" type="image/png" sizes="48x48" href="/favicon-48.png" />
		<link rel="apple-touch-icon" href="/apple-touch-icon.png" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content="RebotGames is a small independent game studio currently building Megabait." />
		<title>RebotGames — Megabait</title>

		<meta property="og:type" content="website" />
		<meta property="og:url" content="https://rebotgames.com/" />
		<meta property="og:title" content="RebotGames — Megabait" />
		<meta property="og:description" content="A brutal top-down obstacle course where every second counts. Survive deadly hazard rooms, leave a bloody trail of your past mistakes, and uncover every secret on your path to 100% completion." />
		<meta property="og:image" content="https://rebotgames.com/images/capsule_horizontal.jpg" />

		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content="RebotGames — Megabait" />
		<meta name="twitter:description" content="A brutal top-down obstacle course where every second counts." />
		<meta name="twitter:image" content="https://rebotgames.com/images/capsule_horizontal.jpg" />
	</head>
	<body>
		<Hero />
		<main>
			<About />
			<GameSection />
		</main>
		<Footer />
	</body>
</html>

<style is:global>
	:root {
		--color-bg: #0b1014;
		--color-fg: #f1f5f9;
		--color-muted: #94a3b8;
		--color-border: #1f2933;
		--color-accent: #7fffd4;
	}

	* {
		box-sizing: border-box;
	}

	html,
	body {
		margin: 0;
		padding: 0;
	}

	body {
		background: var(--color-bg);
		color: var(--color-fg);
		font-family: system-ui, -apple-system, "Segoe UI", Roboto, sans-serif;
	}

	a {
		color: var(--color-accent);
		text-decoration: none;
	}
</style>
